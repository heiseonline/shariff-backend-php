{
    "name": "heise/shariff",
    "keywords": [
        "heise",
        "social buttons",
        "shariff"
    ],
    "description": "PHP backend for Shariff. Shariff enables website users to share their favorite content without compromising their privacy.",
    "homepage": "https://github.com/heiseonline/shariff-backend-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Philipp Busse",
            "email": "pmb@heise.de"
        }
    ],
    "require": {
        "php": "^8.2 <8.6",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.10.0",
        "laminas/laminas-cache": "^4.3",
        "laminas/laminas-cache-storage-adapter-filesystem": "^3.2",
        "laminas/laminas-cache-storage-adapter-memory": "^3.2",
        "psr/log": "^1 | ^2 | ^3.0.2"
    },
    "require-dev": {
        "captainhook/captainhook": "^5.19",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpmd/phpmd": "^2.15",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^9.6.34"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2.0"
        }
    },
    "autoload": {
        "psr-4": {
            "Heise\\Shariff\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Heise\\Tests\\Shariff\\": "tests"
        }
    },
    "scripts": {
        "cs-fixer-dry": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "cs-fixer-fix": "vendor/bin/php-cs-fixer fix --diff",
        "phpunit": "vendor/bin/phpunit",
        "phpunit-coverage": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-text -v",
        "phpmd": "vendor/bin/phpmd src,index.php gitlab phpmd.xml",
        "phpstan": "vendor/bin/phpstan analyse --no-progress --error-format gitlab src index.php",
        "lint": "sh lint.sh",
        "check": [
            "@lint",
            "@cs-fixer-dry",
            "@phpmd",
            "@phpstan",
            "@phpunit"
        ]
    }
}
